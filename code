import java.util.*;
class Main
{
    static long factorial(int n)
    {
        if(n==0 || n==1)
        {
            return 1;
        }
        return n*factorial(n-1);
    }
    public static void main(String[] args)
    {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        long res = factorial(n);
        System.out.println("The Factorial of " +n+ " is : "+res);
    }
}
